# =============================================================================
# Vaccination Reminder Backend — Environment Variables
# Copy to .env and fill in values. See docs/ENVIRONMENT.md for platform setup.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=development
CRON_TZ=Africa/Kigali
# Vite dev server origin — used for CORS and WebSocket origin checks
FRONTEND_URL=http://localhost:5173

# --- Supabase (PostgreSQL + Phone Auth JWT) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- Firebase Cloud Messaging (Web Push) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Resend (Email fallback) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=reminders@yourdomain.com

# --- Africa's Talking (SMS fallback) ---
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SENDER_ID=
AFRICASTALKING_ENABLED=false

# --- Notification strategy ---
NOTIFICATION_SMS_FALLBACK=true

# --- OpenRouter (AI Assistant) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_TITLE=Vaccination Reminder Rwanda
